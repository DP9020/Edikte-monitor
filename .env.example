# Edikte-Monitor – Environment-Variablen
# Lokal als `.env` ablegen (gitignored). Production-Secrets in GitHub Actions.

# === Production (GitHub Actions Secrets) ===
NOTION_TOKEN=
NOTION_DATABASE_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_CHAT_ID_BENJAMIN=
TELEGRAM_CHAT_ID_CHRISTOPHER=
OPENAI_API_KEY=
SMTP_USER=

# E-Mail-Versand: Brevo SMTP ist primärer Pfad, SendGrid Legacy-Fallback
BREVO_SMTP_KEY=
BREVO_SMTP_LOGIN=
SENDGRID_API_KEY=

# Modus-Schalter (alle "false" oder "true")
BRIEF_ONLY=false
# GDRIVE_ONLY=false       # nur Drive-Sync, kein Scraping/Brief
# WOCHENBERICHT=false     # Mo-Wochenbericht-Modus

GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_DRIVE_FOLDER_ID=

# Optional: Sanity-Threshold gegen Pagination-Abbruch (default 500)
# NOTION_MIN_PAGES=500

# === NIM-Eval (nur lokal, nicht in GitHub Actions) ===
# Format: nvapi-...
# Bezug: https://build.nvidia.com/settings/api-keys
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
